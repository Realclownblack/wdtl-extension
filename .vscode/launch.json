{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run W Language extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--open-url",
        "vscode://file/${workspaceFolder}/examples/exemplo.w"
      ],
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "preLaunchTask": "${defaultBuildTask}"
    }
  ]
}
